    }
    with open(os.path.join(output_dir, 'sim_params.json'), 'w') as f:
        json.dump(sim_params, f, indent=4)

    print("All data saved successfully to " + output_dir)
    print("Simulation finished.")

if __name__ == '__main__':
    run_simulation()

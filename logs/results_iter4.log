import sys
import os
sys.path.insert(0, os.path.abspath("codebase"))
import torch
import numpy as np
import json

def get_k_grid(n):
    k = torch.fft.fftfreq(n, d=1.0/n)
    kx, ky = torch.meshgrid(k, k, indexing='ij')
    k2 = kx**2 + ky**2
    k2[0, 0] = 1.0
    return kx, ky, k2

class DNS_Solver:
    def __init__(self, n=512, nu_h=1e-28, p=4, lambda_ekman=0.05):
        self.n = n
        self.device = torch.device('cuda')
        kx, ky, k2 = get_k_grid(n)
        self.kx = kx[:, :n//2 + 1].to(self.device)
        self.ky = ky[:, :n//2 + 1].to(self.device)
        self.k2 = k2[:, :n//2 + 1].to(self.device)
        self.inv_k2 = 1.0 / self.k2
        self.inv_k2[0, 0] = 0.0
        self.diss_op = (-nu_h * (self.k2**p) - lambda_ekman).to(self.device)
        self.force_mask = ((self.k2 >= 10**2) & (self.k2 <= 12**2)).float().to(self.device)
        self.force_amp = 1.0

    def get_velocity(self, omega_hat):
        psi_hat = -omega_hat * self.inv_k2
        u_hat = 1j * self.ky * psi_hat
        v_hat = -1j * self.kx * psi_hat
        u = torch.fft.irfft2(u_hat, s=(self.n, self.n))
        v = torch.fft.irfft2(v_hat, s=(self.n, self.n))
        return u, v

    def rhs(self, omega_hat, noise=None):
        u, v = self.get_velocity(omega_hat)
        omega = torch.fft.irfft2(omega_hat, s=(self.n, self.n))
        u_omega = u * omega
        v_omega = v * omega
        nonlin = 1j * self.kx * torch.fft.rfft2(u_omega) + 1j * self.ky * torch.fft.rfft2(v_omega)
        if noise is None: noise = torch.randn_like(omega_hat) + 1j * torch.randn_like(omega_hat)
        forcing = self.force_amp * noise * self.force_mask
        return -nonlin + forcing

    def step(self, omega_hat, dt, noise=None):
        k1 = self.rhs(omega_hat, noise)
        k2 = self.rhs(omega_hat + 0.5 * dt * k1, noise)
        k3 = self.rhs(omega_hat + 0.5 * dt * k2, noise)
        k4 = self.rhs(omega_hat + dt * k3, noise)
        return (omega_hat + (dt/6.0) * (k1 + 2*k2 + 2*k3 + k4)) * torch.exp(self.diss_op * dt)

if __name__ == '__main__':
    data_dir = 'data/'
    os.makedirs(data_dir, exist_ok=True)
    solver = DNS_Solver()
    omega_hat = torch.zeros((512, 512//2 + 1), dtype=torch.complex64, device='cuda')
    for _ in range(60000):
        omega_hat = solver.step(omega_hat, 0.001)
    u, v = solver.get_velocity(omega_hat)
    u_rms = torch.sqrt(torch.mean(u**2 + v**2))
    t_l = (2 * np.pi) / u_rms
    n_tracers = 5000
    tracers = torch.rand((n_tracers, 2), device='cuda') * 2 * np.pi
    # Reduced snapshot count to avoid OSError
    n_snaps = 5000
    dt_snap = (50 * t_l.item()) / n_snaps
    pos_map = np.memmap(os.path.join(data_dir, 'tracer_positions.npy'), dtype='float32', mode='w+', shape=(n_snaps, n_tracers, 2))
    for i in range(n_snaps):
        for _ in range(int(dt_snap / 0.01)):
            omega_hat = solver.step(omega_hat, 0.01)
        u, v = solver.get_velocity(omega_hat)
        idx = (tracers / (2 * np.pi / 512)).long() % 512
        u_tr = u[idx[:, 0], idx[:, 1]]
        v_tr = v[idx[:, 0], idx[:, 1]]
        tracers = (tracers + torch.stack([u_tr, v_tr], dim=1) * dt_snap) % (2 * np.pi)
        pos_map[i] = tracers.cpu().numpy()
    print('Production run completed. Tracer positions saved.')

# filename: codebase/step_1.py
import torch
import numpy as np
import os

def get_k_grid(n):
    k = torch.fft.fftfreq(n, d=1.0/n)
    kx, ky = torch.meshgrid(k, k, indexing='ij')
    k2 = kx**2 + ky**2
    k2[0, 0] = 1.0
    return kx, ky, k2

class DNS_Solver:
    def __init__(self, n=512, nu_h=1e-28, p=4, lambda_ekman=0.05):
        self.n = n
        self.device = torch.device('cuda')
        kx, ky, k2 = get_k_grid(n)
        
        # Slice to RFFT format (N, N//2 + 1)
        self.kx = kx[:, :n//2 + 1].to(self.device)
        self.ky = ky[:, :n//2 + 1].to(self.device)
        self.k2 = k2[:, :n//2 + 1].to(self.device)
        
        self.inv_k2 = 1.0 / self.k2
        self.inv_k2[0, 0] = 0.0
        self.diss_op = (-nu_h * (self.k2**p) - lambda_ekman).to(self.device)

    def get_velocity(self, omega_hat):
        psi_hat = -omega_hat * self.inv_k2
        u_hat = 1j * self.ky * psi_hat
        v_hat = -1j * self.kx * psi_hat
        u = torch.fft.irfft2(u_hat, s=(self.n, self.n))
        v = torch.fft.irfft2(v_hat, s=(self.n, self.n))
        return u, v

    def rhs(self, omega_hat):
        u, v = self.get_velocity(omega_hat)
        omega = torch.fft.irfft2(omega_hat, s=(self.n, self.n))
        u_omega = u * omega
        v_omega = v * omega
        nonlin = 1j * self.kx * torch.fft.rfft2(u_omega) + 1j * self.ky * torch.fft.rfft2(v_omega)
        return -nonlin

    def step(self, omega_hat, dt):
        k1 = self.rhs(omega_hat)
        k2 = self.rhs(omega_hat + 0.5 * dt * k1)
        k3 = self.rhs(omega_hat + 0.5 * dt * k2)
        k4 = self.rhs(omega_hat + dt * k3)
        return (omega_hat + (dt/6.0) * (k1 + 2*k2 + 2*k3 + k4)) * torch.exp(self.diss_op * dt)

if __name__ == '__main__':
    solver = DNS_Solver()
    omega_hat = torch.zeros((512, 512//2 + 1), dtype=torch.complex64, device='cuda')
    for _ in range(100):
        omega_hat = solver.step(omega_hat, 0.001)
    print("Simulation initialized and spinup completed.")
    print("Shapes: omega_hat " + str(omega_hat.shape))

### Step 4 (engineer): Visualize the computed time series and perform stationarity tests.
**Executed code:**
```python
# filename: codebase/step_4.py
import sys
import os
sys.path.insert(0, os.path.abspath("codebase"))
sys.path.insert(0, "/home/node/data/compsep_data/")
import numpy as np
import os
import time
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
from statsmodels.tsa.stattools import adfuller, kpss
from scipy.signal import detrend
from scipy.optimize import curve_fit


def run_stationarity_tests(series, name):
    """
    Performs and prints results of ADF and KPSS stationarity tests on a time series.

    Args:
        series (np.ndarray): The time series data to test.
        name (str): The name of the variable being tested, for printing.
    """
    print("\n--- Stationarity Tests for " + name + " ---")
    
    valid_series = series[~np.isnan(series)]
    if len(valid_series) < 20:
        print("  Not enough data points (" + str(len(valid_series)) + ") to perform tests.")
        return
        
    detrended_series = detrend(valid_series)

    print("Augmented Dickey-Fuller (ADF) Test (H0: Non-Stationary):")
    adf_result = adfuller(detrended_series)
    print("  ADF Statistic: " + "{:.4f}".format(adf_result[0]))
    print("  p-value: " + "{:.4f}".format(adf_result[1]))
    print("  Result: " + ("Reject H0 (Stationary)" if adf_result[1] < 0.05 else "Fail to Reject H0 (Non-Stationary)"))

    print("\nKwiatkowski-Phillips-Schmidt-Shin (KPSS) Test (H0: Stationary):")
    try:
        with np.testing.suppress_warnings() as sup:
            sup.filter(UserWarning, "The test statistic is outside of the range of p-values")
            kpss_result = kpss(detrended_series, regression='c', nlags="auto")
        print("  KPSS Statistic: " + "{:.4f}".format(kpss_result[0]))
        print("  p-value: " + "{:.4f}".format(kpss_result[1]))
        print("  Result: " + ("Reject H0 (Non-Stationary)" if kpss_result[1] < 0.05 else "Fail to Reject H0 (Stationary)"))
    except Exception as e:
        print("  KPSS test failed: " + str(e))
    print("--------------------------------" + "-" * len(name))


def power_law_fit_func(x, a, b, c):
    """
    Power law function for fitting alpha vs k_peak.
    
    Args:
        x (np.ndarray): Input data (k_peak / k_box).
        a, b, c (float): Fitting parameters.
        
    Returns:
        np.ndarray: The computed values from the function.
    """
    return a + b * np.power(x, c)


def main():
    """
    Main function to visualize time series and perform stationarity tests.
    """
    data_dir = "data/"
    input_filepath = os.path.join(data_dir, "time_series_observables.npz")
    
    if not os.path.exists(input_filepath):
        raise FileNotFoundError("Could not find the input file: " + input_filepath)
        
    data = np.load(input_filepath)
    
    window_times = data['window_times']
    alpha_mcculloch = data['alpha_mcculloch']
    alpha_hill = data['alpha_hill']
    gamma = data['gamma']
    nu = data['nu']
    k_peak = data['k_peak']
    d_vv = data['d_vv']
    
    k_box = 1.0
    
    run_stationarity_tests(alpha_mcculloch, "alpha (McCulloch)")
    run_stationarity_tests(gamma, "gamma (MSD)")
    run_stationarity_tests(nu, "nu (VACF)")
    
    current_timestamp = str(int(time.time()))
    plt.rcParams['text.usetex'] = False

    fig, axes = plt.subplots(5, 1, figsize=(12, 18), sharex=True)
    fig.suptitle("Temporal Evolution of Statistical Observables", fontsize=16)
    
    axes[0].plot(window_times, alpha_mcculloch, 'o-', label='alpha (McCulloch)')
    axes[0].plot(window_times, alpha_hill, 's--', label='alpha (Hill)', alpha=0.6)
    axes[0].set_ylabel("Levy Index alpha")
    axes[0].legend()
    axes[0].grid(True)
    axes[0].set_ylim(0, 2.5)
    axes[0].set_title("Alpha (Hill estimator values may be outside the plotted range)")

    axes[1].plot(window_times, gamma, 'o-')
    axes[1].set_ylabel("MSD Exponent gamma")
    axes[1].grid(True)

    axes[2].plot(window_times, nu, 'o-')
    axes[2].set_ylabel("VACF Decay Exponent nu")
    axes[2].grid(True)

    axes[3].plot(window_times, d_vv, 'o-')
    axes[3].set_ylabel("d_vv Estimate")
    axes[3].set_title("d_vv Estimate (Not Computed in Simulation)")
    axes[3].grid(True)

    axes[4].plot(window_times, k_peak + 1, 'o-')
    axes[4].set_ylabel("Peak Wavenumber k_peak")
    axes[4].set_xlabel("Time (s)")
    axes[4].grid(True)

    plt.tight_layout(rect=[0, 0, 1, 0.98])
    plot1_filename = "observables_evolution_1_" + current_timestamp + ".png"
    plot1_filepath = os.path.join(data_dir, plot1_filename)
    plt.savefig(plot1_filepath, dpi=300)
    plt.close(fig)
    print("\nTime series evolution plot saved to " + plot1_filepath)

    valid_mask = ~np.isnan(alpha_mcculloch) & ~np.isnan(k_peak)
    alpha_valid = alpha_mcculloch[valid_mask]
    k_peak_valid = k_peak[valid_mask] + 1
    
    if len(alpha_valid) > 3:
        fig2, ax2 = plt.subplots(figsize=(10, 7))
        
        k_peak_norm = k_peak_valid / k_box
        ax2.scatter(k_peak_norm, alpha_valid, label='Data')
        
        if np.std(k_peak_norm) > 0.2:
            try:
                p0 = [1.5, 0.1, -1.0]
                popt, pcov = curve_fit(power_law_fit_func, k_peak_norm, alpha_valid, p0=p0, maxfev=5000)
                perr = np.sqrt(np.diag(pcov))
                
                print("\n--- Fit Results for alpha = a + b*(k_peak/k_box)^c ---")
                print("  Fitted parameters (a, b, c):")
                print("    a = " + "{:.4f}".format(popt[0]) + " +/- " + "{:.4f}".format(perr[0]))
                print("    b = " + "{:.4f}".format(popt[1]) + " +/- " + "{:.4f}".format(perr[1]))
                print("    c = " + "{:.4f}".format(popt[2]) + " +/- " + "{:.4f}".format(perr[2]))
                print("----------------------------------------------------")

                k_fit = np.linspace(min(k_peak_norm), max(k_peak_norm), 200)
                alpha_fit = power_law_fit_func(k_fit, *popt)
                fit_label = 'Fit: a+b*k^c\na={:.2f}, b={:.2f}, c={:.2f}'.format(popt[0], popt[1], popt[2])
                ax2.plot(k_fit, alpha_fit, 'r-', label=fit_label)
                
            except RuntimeError as e:
                print("\nCould not fit the power law to alpha vs k_peak data: " + str(e))
        else:
            fit_text = "Fit not performed:\nInsufficient variation in k_peak"
            ax2.text(0.05, 0.95, fit_text, transform=ax2.transAxes, fontsize=12,
                     verticalalignment='top', bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5))
            print("\nFit not performed for alpha vs k_peak: Insufficient variation in k_peak.")

        ax2.set_xlabel("Normalized Peak Wavenumber (k_peak / k_box)")
        ax2.set_ylabel("Levy Index alpha (McCulloch)")
        ax2.set_title("Levy Index vs. Spectral Condensation State")
        ax2.legend()
        ax2.grid(True)
        
        plt.tight_layout()
        plot2_filename = "alpha_vs_kpeak_1_" + current_timestamp + ".png"
        plot2_filepath = os.path.join(data_dir, plot2_filename)
        plt.savefig(plot2_filepath, dpi=300)
        plt.close(fig2)
        print("Alpha vs k_peak plot saved to " + plot2_filepath)
    else:
        print("\nNot enough valid data points to plot or fit alpha vs k_peak.")


if __name__ == '__main__':
    main()

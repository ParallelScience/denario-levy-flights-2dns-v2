# filename: codebase/step_1.py
import sys
import os
sys.path.insert(0, os.path.abspath("codebase"))
sys.path.insert(0, "/home/node/data/compsep_data/")
import torch
import numpy as np
import os
import json
import time
import sys


def setup_simulation(N, L, nu_h, p, k_force_min, k_force_max, device):
    """
    Initializes wavenumbers, masks, and operators for the simulation.

    Args:
        N (int): Grid resolution.
        L (float): Domain size.
        nu_h (float): Hyperviscosity coefficient.
        p (int): Hyperviscosity power.
        k_force_min (int): Minimum forcing wavenumber.
        k_force_max (int): Maximum forcing wavenumber.
        device (torch.device): The device to run the simulation on.

    Returns:
        tuple: A tuple containing wavenumbers, masks, and operators.
    """
    dx = L / N
    k = torch.fft.fftfreq(N, d=dx / (2 * np.pi)).to(device)
    kr = torch.fft.rfftfreq(N, d=dx / (2 * np.pi)).to(device)
    kx, ky = torch.meshgrid(k, kr, indexing='ij')
    k2 = kx**2 + ky**2
    km = torch.sqrt(k2)
    
    k2_nz = k2.clone()
    k2_nz[0, 0] = 1.0
    
    diss_op = -nu_h * (k2**p)
    
    force_mask = (km >= k_force_min) & (km <= k_force_max)
    
    k_max_dealias = N / 3.0
    dealias_mask = (torch.abs(kx) < k_max_dealias) & (torch.abs(ky) < k_max_dealias)
    
    return dx, kx, ky, k2, km, k2_nz, diss_op, force_mask, dealias_mask


def get_velocity_from_vorticity(omega_hat, kx, ky, k2_nz):
    """
    Computes velocity field in spectral space from vorticity.

    Args:
        omega_hat (torch.Tensor): Vorticity in spectral space.
        kx (torch.Tensor): Wavenumbers in x-direction.
        ky (torch.Tensor): Wavenumbers in y-direction.
        k2_nz (torch.Tensor): Squared wavenumber magnitude, avoiding zero.

    Returns:
        tuple: Velocity components (u_hat, v_hat) in spectral space.
    """
    psi_hat = -omega_hat / k2_nz
    u_hat = 1j * ky * psi_hat
    v_hat = -1j * kx * psi_hat
    return u_hat, v_hat


def get_energy(omega_hat, kx, ky, k2_nz, N, L):
    """
    Computes total kinetic energy.

    Args:
        omega_hat (torch.Tensor): Vorticity in spectral space.
        kx (torch.Tensor): Wavenumbers in x-direction.
        ky (torch.Tensor): Wavenumbers in y-direction.
        k2_nz (torch.Tensor): Squared wavenumber magnitude.
        N (int): Grid resolution.
        L (float): Domain size.

    Returns:
        float: Total kinetic energy.
    """
    u_hat, v_hat = get_velocity_from_vorticity(omega_hat, kx, ky, k2_nz)
    energy_density = 0.5 * (torch.abs(u_hat)**2 + torch.abs(v_hat)**2)
    energy_density[0, 0] = 0
    return torch.sum(energy_density).item() * (L / (2 * np.pi * N))**2


def get_energy_spectrum(omega_hat, kx, ky, k2_nz, km, N, L):
    """
    Computes the 1D azimuthally-averaged energy spectrum.

    Args:
        omega_hat, kx, ky, k2_nz, km: Tensors for spectral calculations.
        N (int): Grid resolution.
        L (float): Domain size.

    Returns:
        np.ndarray: 1D energy spectrum.
    """
    u_hat, v_hat = get_velocity_from_vorticity(omega_hat, kx, ky, k2_nz)
    energy_density_2d = 0.5 * (torch.abs(u_hat)**2 + torch.abs(v_hat)**2)
    
    k_bins = torch.arange(0.5, N // 2 + 1, 1.0, device=omega_hat.device)
    E_k = torch.zeros_like(k_bins)
    
    for i, k_bin in enumerate(k_bins):
        mask = (km >= k_bin - 0.5) & (km < k_bin + 0.5)
        if torch.any(mask):
            E_k[i] = torch.sum(energy_density_2d[mask])
            
    return E_k.cpu().numpy() * (L / (2 * np.pi * N))**2


def get_diagnostics(omega_hat, kx, ky, k2_nz, km, N, L):
    """
    Computes various diagnostic quantities.

    Args:
        omega_hat, kx, ky, k2_nz, km: Tensors for spectral calculations.
        N (int): Grid resolution.
        L (float): Domain size.

    Returns:
        tuple: A tuple of diagnostic values.
    """
    E_total = get_energy(omega_hat, kx, ky, k2_nz, N, L)
    U_rms = np.sqrt(2 * E_total)
    
    omega = torch.fft.irfft2(omega_hat, s=(N, N))
    omega_rms = torch.sqrt(torch.mean(omega**2)).item()
    
    T_L = L / U_rms if U_rms > 0 else np.inf
    
    E_k = get_energy_spectrum(omega_hat, kx, ky, k2_nz, km, N, L)
    k_peak = np.argmax(E_k) if E_total > 0 else 0.0
    
    return E_total, U_rms, omega_rms, T_L, float(k_peak)


def nonlinear_term(omega_hat, kx, ky, k2_nz, N):
    """
    Computes the nonlinear advection term in spectral space.

    Args:
        omega_hat, kx, ky, k2_nz: Tensors for spectral calculations.
        N (int): Grid resolution.

    Returns:
        torch.Tensor: The nonlinear term in spectral space.
    """
    u_hat, v_hat = get_velocity_from_vorticity(omega_hat, kx, ky, k2_nz)
    u = torch.fft.irfft2(u_hat, s=(N, N))
    v = torch.fft.irfft2(v_hat, s=(N, N))
    omega = torch.fft.irfft2(omega_hat, s=(N, N))
    
    adv_x = torch.fft.rfft2(u * omega)
    adv_y = torch.fft.rfft2(v * omega)
    
    return - (1j * kx * adv_x + 1j * ky * adv_y)


def get_dt(omega_hat, kx, ky, k2_nz, N, dx, CFL):
    """
    Computes adaptive timestep based on CFL condition.

    Args:
        omega_hat, kx, ky, k2_nz: Tensors for spectral calculations.
        N (int): Grid resolution.
        dx (float): Grid spacing.
        CFL (float): CFL number.

    Returns:
        float: The calculated time step.
    """
    u_hat, v_hat = get_velocity_from_vorticity(omega_hat, kx, ky, k2_nz)
    u = torch.fft.irfft2(u_hat, s=(N, N))
    v = torch.fft.irfft2(v_hat, s=(N, N))
    U_max = torch.sqrt(u**2 + v**2).max().item()
    return min(CFL * dx / U_max, 0.5) if U_max > 1e-8 else 0.05


def interpolate_velocity(u, v, tracer_pos, L):
    """
    Interpolates velocity at tracer positions using bilinear interpolation.

    Args:
        u (torch.Tensor): U-velocity field.
        v (torch.Tensor): V-velocity field.
        tracer_pos (torch.Tensor): Tracer positions.
        L (float): Domain size.

    Returns:
        torch.Tensor: Interpolated velocities at tracer positions.
    """
    pos_norm = (torch.remainder(tracer_pos, L) / L) * 2.0 - 1.0
    grid = torch.stack([u, v], dim=0).unsqueeze(0)
    pos_grid = pos_norm.view(1, 1, -1, 2)
    
    interpolated_vel = torch.nn.functional.grid_sample(
        grid, pos_grid, mode='bilinear', padding_mode='zeros', align_corners=True
    )
    return interpolated_vel.view(2, -1).T


def rk4_tracer_step(tracer_pos, omega_hat, dt, kx, ky, k2_nz, N, L):
    """
    Performs one RK4 step for tracer advection.

    Args:
        tracer_pos (torch.Tensor): Current tracer positions.
        omega_hat (torch.Tensor): Current vorticity in spectral space.
        dt (float): Time step.
        kx, ky, k2_nz: Wavenumber tensors.
        N (int): Grid resolution.
        L (float): Domain size.

    Returns:
        torch.Tensor: New tracer positions.
    """
    def get_vel_at_pos(pos, current_omega_hat):
        u_hat, v_hat = get_velocity_from_vorticity(current_omega_hat, kx, ky, k2_nz)
        u = torch.fft.irfft2(u_hat, s=(N, N))
        v = torch.fft.irfft2(v_hat, s=(N, N))
        return interpolate_velocity(u, v, pos, L)

    k1 = get_vel_at_pos(tracer_pos, omega_hat)
    k2 = get_vel_at_pos(tracer_pos + 0.5 * dt * k1, omega_hat)
    k3 = get_vel_at_pos(tracer_pos + 0.5 * dt * k2, omega_hat)
    k4 = get_vel_at_pos(tracer_pos + dt * k3, omega_hat)
    
    new_pos = tracer_pos + (dt / 6.0) * (k1 + 2*k2 + 2*k3 + k4)
    return torch.remainder(new_pos, L)


def rk4_if_step(omega_hat, dt, force_amp, force_mask, IF, dealias_mask, kx, ky, k2_nz, N):
    """
    Performs one RK4 step with integrating factor for the fluid.

    Args:
        omega_hat (torch.Tensor): Current vorticity in spectral space.
        dt (float): Time step.
        force_amp (float): Forcing amplitude.
        force_mask (torch.Tensor): Forcing mask.
        IF (torch.Tensor): Integrating factor.
        dealias_mask (torch.Tensor): Dealiasing mask.
        kx, ky, k2_nz: Wavenumber tensors.
        N (int): Grid resolution.

    Returns:
        torch.Tensor: New vorticity in spectral space.
    """
    k1 = nonlinear_term(omega_hat, kx, ky, k2_nz, N)
    k2 = nonlinear_term(omega_hat + 0.5 * dt * k1, kx, ky, k2_nz, N)
    k3 = nonlinear_term(omega_hat + 0.5 * dt * k2, kx, ky, k2_nz, N)
    k4 = nonlinear_term(omega_hat + dt * k3, kx, ky, k2_nz, N)
    
    omega_hat_new = IF * (omega_hat + dt * (k1 + 2*k2 + 2*k3 + k4) / 6.0)
    
    phi = torch.exp(2j * np.pi * torch.rand_like(omega_hat))
    omega_hat_new += (force_amp * np.sqrt(dt)) * phi * force_mask
    
    omega_hat_new *= dealias_mask
    return omega_hat_new


def main():
    """
    Main function to run the 2D turbulence simulation.
    """
    # Parameters
    N = 512
    L = 2 * np.pi
    nu_h = 1e-28
    p = 4
    epsilon_inj = 0.1
    k_force_min, k_force_max = 3, 5
    CFL = 0.4
    T_spinup = 10.0
    N_tracers = 5000
    N_coarse = 128
    dt_snap = 0.01
    dt_vel = 0.5
    
    output_dir = "/home/node/work/projects/levy_flights_2dns_v2/data/"
    os.makedirs(output_dir, exist_ok=True)
    
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print("Using device: " + str(device))

    # Setup
    dx, kx, ky, k2, km, k2_nz, diss_op, force_mask, dealias_mask = setup_simulation(
        N, L, nu_h, p, k_force_min, k_force_max, device
    )
    
    # Force Calibration
    print("Calibrating forcing amplitude...")
    omega_calib = torch.zeros(N, N // 2 + 1, dtype=torch.cfloat, device=device)
    dE_acc = 0.0
    dt_cal = 0.01
    n_cal_steps = 100
    for _ in range(n_cal_steps):
        E0 = get_energy(omega_calib, kx, ky, k2_nz, N, L)
        phi = torch.exp(2j * np.pi * torch.rand_like(omega_calib))
        omega_calib += np.sqrt(dt_cal) * phi * force_mask
        dE_acc += get_energy(omega_calib, kx, ky, k2_nz, N, L) - E0
    
    dE_per_amp2 = dE_acc / (n_cal_steps * dt_cal)
    force_amp = float(np.sqrt(epsilon_inj / dE_per_amp2))
    print("Calibrated force_amp = " + "{:.2f}".format(force_amp))
    
    # Spinup
    print("Starting spinup...")
    t = 0.0
    omega_hat = torch.zeros(N, N // 2 + 1, dtype=torch.cfloat, device=device)
    last_dt = -1
    IF = None
    
    start_time = time.time()
    while t < T_spinup:
        dt = get_dt(omega_hat, kx, ky, k2_nz, N, dx, CFL)
        if abs(dt - last_dt) / dt > 0.01:
            IF = torch.exp(diss_op * dt)
            last_dt = dt
        
        omega_hat = rk4_if_step(omega_hat, dt, force_amp, force_mask, IF, dealias_mask, kx, ky, k2_nz, N)
        t += dt
        
        if torch.any(torch.isnan(omega_hat)) or torch.any(torch.isinf(omega_hat)):
            raise RuntimeError("NaN/Inf detected during spinup at t=" + "{:.3f}".format(t))
            
    print("Spinup finished at t=" + "{:.2f}".format(t) + ". Time elapsed: " + "{:.2f}".format(time.time() - start_time) + "s")
    
    # Post-spinup setup
    E_total, U_rms, _, T_L, k_peak = get_diagnostics(omega_hat, kx, ky, k2_nz, km, N, L)
    T_prod = 50 * T_L
    print("End of spinup diagnostics: U_rms=" + "{:.3f}".format(U_rms) + ", T_L=" + "{:.3f}".format(T_L) + ", k_peak=" + "{:.1f}".format(k_peak))
    print("Production run will last for T_prod=" + "{:.2f}".format(T_prod))
    
    # Storage pre-check
    est_n_tracer_snaps = int(T_prod / dt_snap)
    est_n_vel_snaps = int(T_prod / dt_vel)
    size_tr_pos = est_n_tracer_snaps * N_tracers * 2 * 4 / 1024**3
    size_vel_snap = est_n_vel_snaps * 2 * N_coarse * N_coarse * 4 / 1024**3
    print("Estimated storage: tracer_positions ~" + "{:.2f}".format(size_tr_pos) + " GB, velocity_snapshots ~" + "{:.2f}".format(size_vel_snap) + " GB")
    if size_tr_pos > 4.0 or size_vel_snap > 4.0:
        print("Warning: Estimated file size exceeds 4GB. Continuing anyway.")

    # Production run
    print("Starting production run...")
    tracer_pos = torch.rand(N_tracers, 2, device=device) * L
    
    tracer_pos_hist = []
    tracer_vel_hist = []
    tracer_times = []
    vel_snapshots = []
    vort_snapshots = []
    vel_times = []
    energy_spec_hist = []
    diagnostics_hist = []
    
    t_prod_start = t
    next_snap_time = t
    next_vel_snap_time = t
    snap_idx = 0
    
    while t < t_prod_start + T_prod:
        dt = get_dt(omega_hat, kx, ky, k2_nz, N, dx, CFL)
        if abs(dt - last_dt) / dt > 0.01:
            IF = torch.exp(diss_op * dt)
            last_dt = dt
            
        # Advect tracers first, then fluid
        tracer_pos = rk4_tracer_step(tracer_pos, omega_hat, dt, kx, ky, k2_nz, N, L)
        omega_hat = rk4_if_step(omega_hat, dt, force_amp, force_mask, IF, dealias_mask, kx, ky, k2_nz, N)
        t += dt
        
        if torch.any(torch.isnan(omega_hat)) or torch.any(torch.isinf(omega_hat)):
            raise RuntimeError("NaN/Inf detected during production at t=" + "{:.3f}".format(t))

        if t >= next_snap_time:
            # Tracer snapshot
            u_hat, v_hat = get_velocity_from_vorticity(omega_hat, kx, ky, k2_nz)
            u = torch.fft.irfft2(u_hat, s=(N, N))
            v = torch.fft.irfft2(v_hat, s=(N, N))
            tracer_vel = interpolate_velocity(u, v, tracer_pos, L)
            
            tracer_pos_hist.append(tracer_pos.cpu().numpy().astype(np.float32))
            tracer_vel_hist.append(tracer_vel.cpu().numpy().astype(np.float32))
            tracer_times.append(t)
            
            # Diagnostics snapshot
            E, U, o, TL, kp = get_diagnostics(omega_hat, kx, ky, k2_nz, km, N, L)
            diagnostics_hist.append((t, E, U, o, TL, kp, 0.0)) # d_vv placeholder
            energy_spec_hist.append(get_energy_spectrum(omega_hat, kx, ky, k2_nz, km, N, L))
            
            next_snap_time += dt_snap
            snap_idx += 1
            
            if snap_idx % 100 == 0:
                progress = (t - t_prod_start) / T_prod * 100
                print("Progress: " + "{:.1f}".format(progress) + "%, t=" + "{:.2f}".format(t) + ", dt=" + "{:.4f}".format(dt))

            if snap_idx % 500 == 0:
                print("Checkpointing at t=" + "{:.2f}".format(t))
                temp_state = {
                    'omega_hat': omega_hat.cpu().numpy(),
                    'tracer_pos': tracer_pos.cpu().numpy(),
                    't': t
                }
                np.save(os.path.join(output_dir, 'checkpoint.npy'), temp_state)

        if t >= next_vel_snap_time:
            # Eulerian field snapshot
            u_hat, v_hat = get_velocity_from_vorticity(omega_hat, kx, ky, k2_nz)
            u = torch.fft.irfft2(u_hat, s=(N, N))
            v = torch.fft.irfft2(v_hat, s=(N, N))
            omega = torch.fft.irfft2(omega_hat, s=(N, N))
            
            factor = N // N_coarse
            pool = torch.nn.AvgPool2d(kernel_size=factor)
            
            u_coarse = pool(u.unsqueeze(0).unsqueeze(0)).squeeze()
            v_coarse = pool(v.unsqueeze(0).unsqueeze(0)).squeeze()
            omega_coarse = pool(omega.unsqueeze(0).unsqueeze(0)).squeeze()
            
            vel_snapshots.append(torch.stack([u_coarse, v_coarse]).cpu().numpy().astype(np.float32))
            vort_snapshots.append(omega_coarse.cpu().numpy().astype(np.float32))
            vel_times.append(t)
            
            next_vel_snap_time += dt_vel

    print("Production run finished. Total time: " + "{:.2f}".format(time.time() - start_time) + "s")

    # Save data
    print("Saving data...")
    np.save(os.path.join(output_dir, 'tracer_positions.npy'), np.array(tracer_pos_hist))
    np.save(os.path.join(output_dir, 'tracer_velocities.npy'), np.array(tracer_vel_hist))
    np.save(os.path.join(output_dir, 'tracer_times.npy'), np.array(tracer_times, dtype=np.float64))
    np.save(os.path.join(output_dir, 'velocity_snapshots.npy'), np.array(vel_snapshots))
    np.save(os.path.join(output_dir, 'vorticity_snapshots.npy'), np.array(vort_snapshots))
    np.save(os.path.join(output_dir, 'vel_times.npy'), np.array(vel_times, dtype=np.float64))
    np.save(os.path.join(output_dir, 'energy_spectrum.npy'), np.array(energy_spec_hist, dtype=np.float64))
    
    diag_dtype = np.dtype([('time', 'f8'), ('E_total', 'f8'), ('E_rms', 'f8'), ('omega_rms', 'f8'), 
                           ('T_L', 'f8'), ('k_peak', 'f8'), ('d_vv_estimate', 'f8')])
    diagnostics_array = np.array(diagnostics_hist, dtype=diag_dtype)
    np.save(os.path.join(output_dir, 'diagnostics.npy'), diagnostics_array)
    
    sim_params = {
        'N': N, 'L': L, 'nu_h': nu_h, 'p': p, 'epsilon_inj': epsilon_inj,
        'N_tracers': N_tracers, 'N_coarse': N_coarse,
        'dt_snap': dt_snap, 'dt_vel': dt_vel,
        'T_spinup': T_spinup, 'T_prod': T_prod,
        'T_L_at_start_of_production': T_L,
        'force_amp': force_amp,
        'N_tracer_snaps': len(tracer_times),
        'N_vel_snaps': len(vel_times)
    }
    with open(os.path.join(output_dir, 'sim_params.json'), 'w') as f:
        json.dump(sim_params, f, indent=4)
        
    print("All data saved successfully.")

if __name__ == '__main__':
    main()

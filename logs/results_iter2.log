# filename: codebase/step_2.py
import sys
import os
sys.path.insert(0, os.path.abspath("codebase"))
sys.path.insert(0, "/home/node/data/compsep_data/")
sys.path.insert(0, "/home/node/data/compsep_data/")
import numpy as np
import json
import os
import time
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt


def load_data(base_path):
    """
    Loads all simulation data files from the specified base path.

    Args:
        base_path (str): The absolute path to the directory containing the data files.

    Returns:
        dict: A dictionary containing all loaded data arrays and parameters.
    """
    print("Loading simulation data...")
    data = {}
    files_to_load = {
        'tracer_positions': 'tracer_positions.npy',
        'tracer_velocities': 'tracer_velocities.npy',
        'tracer_times': 'tracer_times.npy',
        'energy_spectrum': 'energy_spectrum.npy',
        'diagnostics': 'diagnostics.npy',
        'sim_params': 'sim_params.json'
    }

    for key, filename in files_to_load.items():
        path = os.path.join(base_path, filename)
        if filename.endswith('.json'):
            with open(path, 'r') as f:
                data[key] = json.load(f)
        else:
            data[key] = np.load(path)
        print("Loaded " + filename)

    print("\n--- Data Shapes and Types ---")
    for key, value in data.items():
        if isinstance(value, np.ndarray):
            print(key + ": shape=" + str(value.shape) + ", dtype=" + str(value.dtype))
        else:
            print(key + ": " + str(type(value)))
    print("---------------------------\n")
    
    return data


def verify_snapshot_quality(tracer_positions, L):
    """
    Computes the mean tracer displacement per snapshot to check data quality.

    Args:
        tracer_positions (np.ndarray): Array of tracer positions.
        L (float): Domain size from simulation parameters.
    """
    print("Verifying snapshot quality...")
    if tracer_positions.shape[0] < 2:
        print("Not enough snapshots to calculate displacement.")
        return

    r_t0 = tracer_positions[0]
    r_t1 = tracer_positions[1]
    
    dr = r_t1 - r_t0
    dr = dr - L * np.round(dr / L)
    
    distances = np.sqrt(np.sum(dr**2, axis=1))
    mean_displacement = np.mean(distances)
    
    print("Mean tracer displacement per snapshot: " + "{:.4f}".format(mean_displacement))
    
    max_allowed_displacement = 0.3 * L
    if mean_displacement > max_allowed_displacement:
        error_msg = "Snapshot quality check FAILED: Mean displacement (" + "{:.4f}".format(mean_displacement) + ") exceeds threshold (" + "{:.4f}".format(max_allowed_displacement) + ")."
        raise RuntimeError(error_msg)
    else:
        print("Snapshot quality check PASSED.")
    print("")


def analyze_vacf(tracer_velocities, dt_snap, timestamp):
    """
    Calculates and plots the Velocity Autocorrelation Function (VACF).

    Args:
        tracer_velocities (np.ndarray): Array of tracer velocities.
        dt_snap (float): Time interval between tracer snapshots.
        timestamp (str): A timestamp string for unique filenames.
    """
    print("Analyzing Velocity Autocorrelation Function (VACF)...")
    max_lag_steps = min(500, tracer_velocities.shape[0] - 1)
    lags = np.arange(1, max_lag_steps)
    vacf_values = []

    v_sq_mean = np.mean(np.sum(tracer_velocities**2, axis=2))
    if v_sq_mean == 0:
        print("Warning: Mean squared velocity is zero. Cannot compute VACF.")
        return

    for lag in lags:
        v_dot_v_tau = np.sum(tracer_velocities[:-lag] * tracer_velocities[lag:], axis=2)
        vacf_values.append(np.mean(v_dot_v_tau) / v_sq_mean)
    
    vacf_values = np.array(vacf_values)
    time_lags = lags * dt_snap

    decorr_idx = np.where(vacf_values < 1/np.e)[0]
    if len(decorr_idx) > 0:
        tau_corr_steps = lags[decorr_idx[0]]
        tau_corr_time = time_lags[decorr_idx[0]]
        print("Decorrelation time (tau_corr): " + "{:.4f}".format(tau_corr_time) + " (" + str(tau_corr_steps) + " steps)")
    else:
        tau_corr_time = -1
        print("Correlation did not drop below 1/e within the calculated lags.")

    print("VACF at specific lags (steps):")
    for lag_step in [1, 2, 4, 8, 16]:
        if lag_step < max_lag_steps:
            idx = lag_step - 1
            print("  Lag " + str(lag_step) + ": " + "{:.4f}".format(vacf_values[idx]))

    plt.rcParams['text.usetex'] = False
    fig, ax = plt.subplots(figsize=(10, 6))
    ax.plot(time_lags, vacf_values, marker='o', linestyle='-', markersize=4)
    ax.axhline(1/np.e, color='r', linestyle='--', label='1/e threshold')
    if tau_corr_time > 0:
        ax.axvline(tau_corr_time, color='g', linestyle='--', label='Decorrelation Time = ' + "{:.2f}".format(tau_corr_time))
    ax.set_xlabel("Time Lag (s)")
    ax.set_ylabel("Velocity Autocorrelation C_vv(t)")
    ax.set_title("Lagrangian Velocity Autocorrelation Function")
    ax.grid(True)
    ax.legend()
    ax.set_xlim(left=0)
    ax.set_ylim(bottom=min(0, np.min(vacf_values)*1.1))
    
    plt.tight_layout()
    plot_filename = "vacf_plot_1_" + timestamp + ".png"
    plot_filepath = os.path.join("data", plot_filename)
    plt.savefig(plot_filepath, dpi=300)
    plt.close(fig)
    print("VACF plot saved to " + plot_filepath)
    print("")


def verify_inverse_cascade(energy_spectrum, diagnostics, tracer_times, T_prod, N, timestamp):
    """
    Plots energy spectrum and peak wavenumber evolution to verify the inverse cascade.

    Args:
        energy_spectrum (np.ndarray): 2D array of energy spectra over time.
        diagnostics (np.ndarray): Structured array of diagnostic data.
        tracer_times (np.ndarray): Array of snapshot times.
        T_prod (float): Total production run time.
        N (int): Grid resolution.
        timestamp (str): A timestamp string for unique filenames.
    """
    print("Verifying inverse cascade...")
    plt.rcParams['text.usetex'] = False
    
    # Plot 1: Energy Spectrum Evolution
    fig1, ax1 = plt.subplots(figsize=(10, 6))
    time_fractions = [0.1, 0.3, 0.6, 1.0]
    
    t_start = tracer_times[0]
    
    for frac in time_fractions:
        target_time = t_start + frac * T_prod
        time_idx = np.argmin(np.abs(tracer_times - target_time))
        actual_time = tracer_times[time_idx]
        
        k = np.arange(1, energy_spectrum.shape[1] + 1)
        Ek = energy_spectrum[time_idx]
        
        valid_indices = Ek > 0
        ax1.loglog(k[valid_indices], Ek[valid_indices], label="t = " + "{:.2f}".format(actual_time))

    ax1.set_xlabel("Wavenumber k")
    ax1.set_ylabel("Energy Spectrum E(k)")
    ax1.set_title("Evolution of Energy Spectrum (Inverse Cascade)")
    ax1.grid(True, which="both", ls="--")
    ax1.legend()
    plt.tight_layout()
    
    plot1_filename = "energy_spectrum_evolution_1_" + timestamp + ".png"
    plot1_filepath = os.path.join("data", plot1_filename)
    plt.savefig(plot1_filepath, dpi=300)
    plt.close(fig1)
    print("Energy spectrum evolution plot saved to " + plot1_filepath)

    # Plot 2: Peak Wavenumber Evolution
    fig2, ax2 = plt.subplots(figsize=(10, 6))
    time_diag = diagnostics['time']
    k_peak_diag = diagnostics['k_peak'] + 1 
    
    ax2.plot(time_diag, k_peak_diag)
    ax2.set_xlabel("Time (s)")
    ax2.set_ylabel("Peak Wavenumber k_peak")
    ax2.set_title("Evolution of Peak Wavenumber")
    ax2.grid(True)
    ax2.set_xlim(left=time_diag[0])
    plt.tight_layout()
    
    plot2_filename = "k_peak_evolution_1_" + timestamp + ".png"
    plot2_filepath = os.path.join("data", plot2_filename)
    plt.savefig(plot2_filepath, dpi=300)
    plt.close(fig2)
    print("Peak wavenumber evolution plot saved to " + plot2_filepath)


if __name__ == '__main__':
    try:
        BASE_PATH = "/home/node/work/projects/levy_flights_2dns_v2/data/"
        
        current_timestamp = str(int(time.time()))
        
        simulation_data = load_data(BASE_PATH)
        
        params = simulation_data['sim_params']
        tracer_pos = simulation_data['tracer_positions']
        tracer_vel = simulation_data['tracer_velocities']
        tracer_times = simulation_data['tracer_times']
        energy_spec = simulation_data['energy_spectrum']
        diagnostics = simulation_data['diagnostics']
        
        verify_snapshot_quality(tracer_pos, params['L'])
        analyze_vacf(tracer_vel, params['dt_snap'], current_timestamp)
        verify_inverse_cascade(energy_spec, diagnostics, tracer_times, params['T_prod'], params['N'], current_timestamp)
        
        print("\nVerification script completed successfully.")

    except Exception as e:
        print("An error occurred during the verification process.")
        print(str(e))

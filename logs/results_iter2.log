### Step 3 (engineer): Compute statistical observables across overlapping time windows.
**Executed code:**
```python
# filename: codebase/step_3.py
import sys
import os
sys.path.insert(0, os.path.abspath("codebase"))
sys.path.insert(0, "/home/node/data/compsep_data/")
import numpy as np
import json
import os
import time
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
from scipy.stats import linregress


def load_data(base_path):
    """
    Loads all simulation data files from the specified base path.

    Args:
        base_path (str): The absolute path to the directory containing the data files.

    Returns:
        dict: A dictionary containing all loaded data arrays and parameters.
    """
    print("Loading simulation data...")
    data = {}
    files_to_load = {
        'tracer_positions': 'tracer_positions.npy',
        'tracer_velocities': 'tracer_velocities.npy',
        'tracer_times': 'tracer_times.npy',
        'diagnostics': 'diagnostics.npy',
        'sim_params': 'sim_params.json'
    }

    for key, filename in files_to_load.items():
        path = os.path.join(base_path, filename)
        if not os.path.exists(path):
            raise FileNotFoundError("Could not find required file: " + path)
        if filename.endswith('.json'):
            with open(path, 'r') as f:
                data[key] = json.load(f)
        else:
            data[key] = np.load(path)
        print("Loaded " + filename)
    return data


def periodic_displacement(pos2, pos1, L):
    """
    Computes displacement with periodic boundary conditions.

    Args:
        pos2 (np.ndarray): Final positions.
        pos1 (np.ndarray): Initial positions.
        L (float): Domain size.

    Returns:
        np.ndarray: Displacement vectors.
    """
    dr = pos2 - pos1
    dr = dr - L * np.round(dr / L)
    return dr


def mcculloch_estimator(displacements):
    """
    Computes the Lévy alpha parameter using the McCulloch (1986) quantile method.

    Args:
        displacements (np.ndarray): 1D array of scalar displacements.

    Returns:
        float: The estimated alpha value.
    """
    mcculloch_v_alpha = np.array([
        2.439, 2.468, 2.505, 2.554, 2.618, 2.703, 2.819, 2.981, 3.214, 
        3.569, 4.151, 5.195, 7.434, 13.08, 32.58
    ])
    mcculloch_alpha = np.array([
        2.00, 1.90, 1.80, 1.70, 1.60, 1.50, 1.40, 1.30, 1.20, 
        1.10, 1.00, 0.90, 0.80, 0.70, 0.60
    ])
    
    q = np.percentile(displacements, [5, 25, 75, 95])
    q5, q25, q75, q95 = q[0], q[1], q[2], q[3]
    
    if (q75 - q25) == 0:
        return np.nan
        
    v_alpha_hat = (q95 - q5) / (q75 - q25)
    
    if v_alpha_hat < mcculloch_v_alpha[0]:
        print("Warning: v_alpha_hat is below table range. Capping alpha at 2.0.")
        return 2.0
    if v_alpha_hat > mcculloch_v_alpha[-1]:
        print("Warning: v_alpha_hat is above table range. Capping alpha at 0.6.")
        return 0.6
        
    alpha_est = np.interp(v_alpha_hat, mcculloch_v_alpha, mcculloch_alpha)
    return alpha_est


def hill_estimator(displacements, k_range, window_idx, timestamp):
    """
    Computes the Hill estimator for alpha and generates a Hill plot.

    Args:
        displacements (np.ndarray): 1D array of scalar displacements.
        k_range (np.ndarray): Range of k values (top order statistics) to use.
        window_idx (int): The index of the current window, for plotting.
        timestamp (str): A timestamp for unique filenames.

    Returns:
        float: The estimated alpha from the stable plateau of the Hill plot.
    """
    X_abs = np.sort(np.abs(displacements))
    n = len(X_abs)
    log_X = np.log(X_abs)
    
    alpha_estimates = []
    for k in k_range:
        if k >= n - 1:
            continue
        threshold_idx = n - k - 1
        log_sum = np.sum(log_X[threshold_idx + 1:])
        hill_sum = log_sum - k * log_X[threshold_idx]
        if hill_sum <= 0:
            alpha_estimates.append(np.nan)
            continue
        alpha_k = k / hill_sum
        alpha_estimates.append(alpha_k)
    
    alpha_estimates = np.array(alpha_estimates)
    
    if window_idx == 0:
        plt.figure(figsize=(10, 6))
        plt.plot(k_range, alpha_estimates, marker='.', linestyle='-')
        plt.xlabel("Number of Top Order Statistics (k)")
        plt.ylabel("Hill Estimator for alpha")
        plt.title("Hill Plot for First Time Window")
        plt.grid(True)
        plt.tight_layout()
        plot_filename = "hill_plot_1_" + timestamp + ".png"
        plot_filepath = os.path.join("data", plot_filename)
        plt.savefig(plot_filepath, dpi=300)
        plt.close()
        print("Hill plot for the first window saved to " + plot_filepath)

    valid_alphas = alpha_estimates[~np.isnan(alpha_estimates)]
    if len(valid_alphas) < 20:
        return np.nan
    
    # Find plateau: region with minimum moving standard deviation
    moving_std = np.array([np.std(valid_alphas[i:i+20]) for i in range(len(valid_alphas)-20)])
    plateau_start = np.argmin(moving_std)
    plateau_alphas = valid_alphas[plateau_start : plateau_start + 20]
    
    return np.median(plateau_alphas)


def compute_observables_for_window(pos, vel, diag, L, dt_snap, T_L, window_idx, timestamp):
    """
    Computes all statistical observables for a single time window.

    Args:
        pos (np.ndarray): Tracer positions for the window.
        vel (np.ndarray): Tracer velocities for the window.
        diag (np.ndarray): Diagnostics data for the window.
        L (float): Domain size.
        dt_snap (float): Snapshot time interval.
        T_L (float): Large-eddy turnover time.
        window_idx (int): Index of the current window.
        timestamp (str): Unique timestamp for filenames.

    Returns:
        dict: A dictionary of computed observables for the window.
    """
    results = {}
    n_snaps = pos.shape[0]

    # --- Alpha calculation ---
    lags_tau = np.array([0.5, 1.0, 2.0]) * T_L
    lag_steps = np.round(lags_tau / dt_snap).astype(int)
    
    alphas_mcculloch = []
    alphas_hill = []
    
    for lag in lag_steps:
        if lag >= n_snaps:
            continue
        dr = periodic_displacement(pos[lag:], pos[:-lag], L)
        for component in [0, 1]: # x and y
            displacements = dr[:, :, component].flatten()
            alphas_mcculloch.append(mcculloch_estimator(displacements))
            
            if component == 0: # Compute Hill only once per lag
                k_range = np.arange(50, min(501, len(displacements)//10))
                if len(k_range) > 0:
                    alphas_hill.append(hill_estimator(displacements, k_range, window_idx, timestamp))

    results['alpha_mcculloch'] = np.nanmedian(alphas_mcculloch)
    results['alpha_hill'] = np.nanmedian(alphas_hill)

    # --- MSD and gamma calculation ---
    max_lag_msd = min(n_snaps - 1, int(2 * T_L / dt_snap))
    lags_msd = np.arange(1, max_lag_msd)
    msd = np.zeros(len(lags_msd))
    for i, lag in enumerate(lags_msd):
        dr = periodic_displacement(pos[lag:], pos[:-lag], L)
        msd[i] = np.mean(np.sum(dr**2, axis=2))
    
    time_lags_msd = lags_msd * dt_snap
    fit_mask_msd = (time_lags_msd > 0.1 * T_L) & (time_lags_msd < T_L)
    if np.sum(fit_mask_msd) > 2:
        log_t = np.log(time_lags_msd[fit_mask_msd])
        log_msd = np.log(msd[fit_mask_msd])
        slope, _, _, _, _ = linregress(log_t, log_msd)
        results['gamma'] = slope
    else:
        results['gamma'] = np.nan

    # --- VACF and nu calculation ---
    max_lag_vacf = min(n_snaps - 1, int(2 * T_L / dt_snap))
    lags_vacf = np.arange(1, max_lag_vacf)
    vacf = np.zeros(len(lags_vacf))
    v_sq_mean = np.mean(np.sum(vel**2, axis=2))
    if v_sq_mean > 0:
        for i, lag in enumerate(lags_vacf):
            v_dot_v_tau = np.sum(vel[:-lag] * vel[lag:], axis=2)
            vacf[i] = np.mean(v_dot_v_tau) / v_sq_mean
    
    time_lags_vacf = lags_vacf * dt_snap
    fit_mask_vacf = (time_lags_vacf > 0.5 * T_L) & (time_lags_vacf < 1.5 * T_L) & (vacf > 0)
    if np.sum(fit_mask_vacf) > 2:
        log_t_vacf = np.log(time_lags_vacf[fit_mask_vacf])
        log_vacf = np.log(vacf[fit_mask_vacf])
        slope, _, _, _, _ = linregress(log_t_vacf, log_vacf)
        results['nu'] = -slope
    else:
        results['nu'] = np.nan

    # --- Mean diagnostics ---
    results['k_peak'] = np.mean(diag['k_peak'])
    results['d_vv'] = np.mean(diag['d_vv_estimate'])
    
    return results


def main():
    """
    Main function to run the non-stationary analysis.
    """
    BASE_PATH = "/home/node/work/projects/levy_flights_2dns_v2/data/"
    OUTPUT_DIR = "data/"
    
    try:
        data = load_data(BASE_PATH)
        params = data['sim_params']
        tracer_pos = data['tracer_positions']
        tracer_vel = data['tracer_velocities']
        tracer_times = data['tracer_times']
        diagnostics = data['diagnostics']
        
        T_L_start = params['T_L_at_start_of_production']
        dt_snap = params['dt_snap']
        L = params['L']
        
        W = 8 * T_L_start
        dW = 2 * T_L_start
        
        window_start_times = np.arange(tracer_times[0], tracer_times[-1] - W, dW)
        
        all_results = []
        window_centers = []
        
        current_timestamp = str(int(time.time()))
        
        for i, t_start in enumerate(window_start_times):
            t_end = t_start + W
            
            idx_start = np.argmin(np.abs(tracer_times - t_start))
            idx_end = np.argmin(np.abs(tracer_times - t_end))
            
            if idx_end - idx_start < 50: # Skip windows with too few points
                continue
            
            print("\nProcessing window " + str(i+1) + "/" + str(len(window_start_times)) + ": t = [" + "{:.2f}".format(t_start) + ", " + "{:.2f}".format(t_end) + "]")
            
            pos_win = tracer_pos[idx_start:idx_end]
            vel_win = tracer_vel[idx_start:idx_end]
            diag_win = diagnostics[idx_start:idx_end]
            
            window_results = compute_observables_for_window(
                pos_win, vel_win, diag_win, L, dt_snap, T_L_start, i, current_timestamp
            )
            
            all_results.append(window_results)
            window_centers.append(t_start + W / 2)
            
            print("  alpha_mcculloch = " + "{:.3f}".format(window_results.get('alpha_mcculloch', np.nan)))
            print("  alpha_hill      = " + "{:.3f}".format(window_results.get('alpha_hill', np.nan)))
            print("  gamma (MSD)     = " + "{:.3f}".format(window_results.get('gamma', np.nan)))
            print("  nu (VACF)       = " + "{:.3f}".format(window_results.get('nu', np.nan)))

        # Save results
        output_path = os.path.join(OUTPUT_DIR, "time_series_observables.npz")
        
        results_dict = {
            'window_times': np.array(window_centers),
            'alpha_mcculloch': np.array([r.get('alpha_mcculloch', np.nan) for r in all_results]),
            'alpha_hill': np.array([r.get('alpha_hill', np.nan) for r in all_results]),
            'gamma': np.array([r.get('gamma', np.nan) for r in all_results]),
            'nu': np.array([r.get('nu', np.nan) for r in all_results]),
            'k_peak': np.array([r.get('k_peak', np.nan) for r in all_results]),
            'd_vv': np.array([r.get('d_vv', np.nan) for r in all_results])
        }
        
        np.savez(output_path, **results_dict)
        print("\nSaved computed time series to " + output_path)

        print("\n--- Summary of Computed Time Series ---")
        for key, value in results_dict.items():
            print(key + ":")
            print(value)
        print("------------------------------------")

    except Exception as e:
        print("An error occurred during the analysis.")
        print(str(e))
        raise

if __name__ == '__main__':
    main()
